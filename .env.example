# =============================================================================
# .env.example — Template public des variables d'environnement
# =============================================================================
# Copiez ce fichier en .env et remplissez vos vraies clés.
# Ce fichier peut être commité : il ne contient aucune valeur sensible.
# =============================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Notion ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- Google ---
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- YouTube ---
YOUTUBE_API_KEY=

# --- Vercel ---
VERCEL_TOKEN=

# --- GitHub ---
GITHUB_TOKEN=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
